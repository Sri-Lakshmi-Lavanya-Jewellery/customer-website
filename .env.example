# ── Customer website environment ──────────────────────────────
# Copy this file to `.env` for local development, or set these as
# environment variables in your host (e.g. Vercel → Project → Settings →
# Environment Variables) for production. `.env` itself is gitignored.
#
# If a variable is unset, the app falls back to its built-in code default.

# Customer-facing product/category API.
# Production (deployed backend):
VITE_API_BASE_URL=https://silver-website-backend.onrender.com/api/v1/customer
# Local backend: http://localhost:3000/api/v1/customer

# Image upload endpoint (admin flows).
VITE_UPLOAD_BASE_URL=https://silver-website-backend.onrender.com/api/v1/upload
# Local backend: http://localhost:3000/api/v1/upload

# Live gold/silver rates API (ported from safe_price_fetcher).
VITE_RATES_API_URL=https://silver-website-backend.onrender.com/api/v1/rates
# Local backend:            http://localhost:3000/api/v1/rates
# Standalone Python fetcher: http://localhost:5006/api/rates

# WhatsApp number for enquiries (digits only, with country code, no +).
VITE_WHATSAPP_NUMBER=917288865969
